{
  "manifest_version": 3,
  "name": "LinkedIn Memory Badge",
  "version": "1.1",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/in/*"],
      "css": ["styles.css"],
      "js": ["content.js"]
    }
  ]
}